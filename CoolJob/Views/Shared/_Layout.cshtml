@using System.Globalization
@using CoolJob.Helpers
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<!DOCTYPE html>
<html lang="@CultureInfo.CurrentCulture.Name">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - @T.Get("Layout.Title")</title>
    <link rel="icon" type="image/x-icon" href="~/ico/icons8-c-в-круге-80.png">
    @if (ViewBag.Css != null)
    {
        foreach (var cssFile in ViewBag.Css as string[])
        {
            <link rel="stylesheet" href="~/@cssFile" />
        }
    }
    <link href="https://fonts.googleapis.com/css2?family=Rubik:wght@400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    
    <style>
        .lang-switcher { display: inline-block; margin-left: 15px; }
        .lang-btn {
            background: #4a6cf7; color: white; border: none; padding: 8px 16px;
            border-radius: 6px; cursor: pointer; font-size: 14px; transition: 0.2s;
        }
        .lang-btn:hover { background: #3a5bd9; }
    </style>
</head>
<body>
<div class="page-container">
    <header class="main-header">
        <div class="header-content">
            <div class="logo-container">
                <h1 class="logo">@T.Get("Layout.Logo")</h1>
                <p class="slogan">@T.Get("Layout.Slogan")</p>
            </div>
            
            <div class="auth-buttons">
                @if (User.Identity.IsAuthenticated)
                {
                    <span class="welcome-text">@T.Get("Layout.Welcome"), @User.Identity.Name!</span>
                }
                else
                {
                    <a asp-controller="Auth" asp-action="Login" class="login-btn">
                        <i class="fas fa-sign-in-alt"></i> @T.Get("Layout.Login")
                    </a>
                    <a asp-controller="Account" asp-action="Register" class="register-btn">
                        <i class="fas fa-user-plus"></i> @T.Get("Layout.Register")
                    </a>
                }
                
                <!-- 👇 Кнопка переключения языка (внутри body, в header) -->
                <form asp-controller="Language" asp-action="Set" method="post" class="lang-switcher">
                    <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                    <button type="submit" name="culture" value="@(CultureInfo.CurrentCulture.Name == "ru" ? "en" : "ru")" 
                            class="lang-btn">
                        @(CultureInfo.CurrentCulture.Name == "ru" ? "ru EN" : "en RU")
                    </button>
                </form>
            </div>
        </div>

        <nav class="main-nav">
            <ul>
                <li>
                    <a href="/" class="nav-link active">
                        <i class="fas fa-home"></i> @T.Get("Layout.Nav.Home")
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Jobs" asp-action="Index">
                        <i class="fas fa-briefcase"></i> @T.Get("Layout.Nav.Jobs")
                    </a>
                </li>
                @if (User.Identity.IsAuthenticated)
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Applications" asp-action="My">
                            <i class="fas fa-file-alt"></i> @T.Get("Layout.Nav.MyApplications")
                        </a>
                    </li>
                }
                @if (User.Identity.IsAuthenticated)
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Profile" asp-action="Index">
                            <i class="fas fa-user"></i> @T.Get("Layout.Nav.Profile")
                        </a>
                    </li>
                    <li class="nav-item">
                        <form asp-controller="Auth" asp-action="Logout" method="post">
                            <button type="submit" class="nav-link btn btn-link">
                                <i class="fas fa-sign-out-alt"></i> @T.Get("Layout.Nav.Logout")
                            </button>
                        </form>
                    </li>
                }
            </ul>
        </nav>
    </header>

    <main class="main-content">
        @RenderBody()
    </main>

    <footer class="main-footer">
        <div class="footer-content">
            <div class="footer-section">
                <h3>@T.Get("Layout.Logo")</h3>
                <p>@T.Get("Layout.Footer.About")</p>
            </div>
            <div class="footer-section">
                <h3>@T.Get("Layout.Footer.Contacts")</h3>
                <p><i class="fas fa-envelope"></i> contact@cooljob.edu</p>
                <p><i class="fas fa-phone"></i> +7 (XXX) XXX-XX-XX</p>
            </div>
            <div class="footer-section">
                <h3>@T.Get("Layout.Footer.Social")</h3>
                <div class="social-icons">
                    <a href="#"><i class="fab fa-vk"></i></a>
                    <a href="#"><i class="fab fa-telegram"></i></a>
                    <a href="#"><i class="fab fa-youtube"></i></a>
                </div>
            </div>
        </div>
        <div class="copyright">
            <p>&copy; @DateTime.Now.Year - @T.Get("Layout.Logo"). @T.Get("Layout.Footer.Copyright").</p>
        </div>
    </footer>
</div>
@RenderSection("scripts", required: false)
</body>
</html>