@using CoolJob.Helpers
@model CoolJob.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = T.Get("Register.Title");
    ViewBag.Css = new[] { "css/style.css", "css/site.css"};
}

<div class="registration-container">
    <h2>@T.Get("Register.Header")</h2>
    <form asp-action="Register" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        
        <div class="form-group">
            <label asp-for="Email">@T.Get("Register.Email")</label>
            <input asp-for="Email" class="form-control" placeholder="@T.Get("Register.EmailPlaceholder")" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>
        
        <div class="form-group">
            <label asp-for="Password">@T.Get("Register.Password")</label>
            <input asp-for="Password" type="password" class="form-control" placeholder="@T.Get("Register.PasswordPlaceholder")" />
            <span asp-validation-for="Password" class="text-danger"></span>
        </div>
        
        <div class="form-group">
            <label asp-for="ConfirmPassword">@T.Get("Register.ConfirmPassword")</label>
            <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="@T.Get("Register.ConfirmPlaceholder")" />
            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
        </div>
        
        <div class="form-group">
            <label asp-for="FirstName">@T.Get("Register.FirstName")</label>
            <input asp-for="FirstName" class="form-control" placeholder="@T.Get("Register.FirstNamePlaceholder")" />
            <span asp-validation-for="FirstName" class="text-danger"></span>
        </div>
        
        <div class="form-group">
            <label asp-for="LastName">@T.Get("Register.LastName")</label>
            <input asp-for="LastName" class="form-control" placeholder="@T.Get("Register.LastNamePlaceholder")" />
            <span asp-validation-for="LastName" class="text-danger"></span>
        </div>
        <button type="submit" class="btn btn-primary">@T.Get("Register.Submit")</button>
    </form>
</div>