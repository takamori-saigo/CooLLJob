@using CoolJob.Helpers
@model Application

@{
    ViewData["Title"] = T.Get("Applications.Details.Title");
    ViewBag.Css = new[] { "css/style.css", "css/MyApplictaions.css" };
}

<div class="application-details">
    <h1><i class="fas fa-file-alt"></i> @T.Get("Applications.Details.Title")</h1>
    
    <div class="detail-card">
        <div class="detail-row">
            <span class="detail-label">@T.Get("Applications.Details.Vacancy"):</span>
            <span class="detail-value">@Model.Job.Title</span>
        </div>
        
        <div class="detail-row">
            <span class="detail-label">@T.Get("Applications.Details.Employer"):</span>
            <span class="detail-value">@Model.Job.Employer.Name</span>
        </div>
        
        <div class="detail-row">
            <span class="detail-label">@T.Get("Applications.Details.Status"):</span>
            <span class="detail-value status-@Model.Status.ToString().ToLower()">
                @T.Get($"Status.{Model.Status}")
            </span>
        </div>
        
        <div class="detail-row">
            <span class="detail-label">@T.Get("Applications.Details.ApplyDate"):</span>
            <span class="detail-value">@Model.ApplyDate.ToString("dd.MM.yyyy HH:mm")</span>
        </div>
        
        @if (!string.IsNullOrEmpty(Model.CoverLetter))
        {
            <div class="detail-row full-width">
                <span class="detail-label">@T.Get("Applications.Details.CoverLetter"):</span>
                <div class="cover-letter">@Model.CoverLetter</div>
            </div>
        }
        
        @if (!string.IsNullOrEmpty(Model.ResumePath))
        {
            <div class="detail-row">
                <span class="detail-label">@T.Get("Applications.Details.Resume"):</span>
                <a href="@Model.ResumePath" target="_blank" class="resume-link">
                    <i class="fas fa-file-pdf"></i> @T.Get("Applications.Details.ViewResume")
                </a>
            </div>
        }
    </div>
    
    <div class="actions">
        <a asp-action="My" class="btn-back">
            <i class="fas fa-arrow-left"></i> @T.Get("Applications.Details.Back")
        </a>
    </div>
</div>