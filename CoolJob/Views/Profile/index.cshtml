@using CoolJob.Helpers
@model CoolJob.Models.User
@{
    ViewData["Title"] = T.Get("Profile.Title");
    ViewBag.Css = new[] { "css/profile.css", "css/style.css" };
}

<div class="profile-container">
    <div class="profile-header">
        <h1><i class="fas fa-user-circle"></i> @T.Get("Profile.Title")</h1>
        <a asp-action="Edit" class="edit-btn">
            <i class="fas fa-edit"></i> @T.Get("Profile.Edit")
        </a>
    </div>

    <div class="profile-card">
        <div class="profile-info">
            <div class="info-row">
                <span class="label">@T.Get("Profile.Name"):</span>
                <span class="value">@Model.FirstName @Model.LastName</span>
            </div>
            <div class="info-row">
                <span class="label">@T.Get("Profile.Email"):</span>
                <span class="value">@Model.Email</span>
            </div>
            <div class="info-row">
                <span class="label">@T.Get("Profile.Faculty"):</span>
                <span class="value">@(Model.Faculty ?? T.Get("Profile.NotSpecified"))</span>
            </div>
        </div>
    </div>

    <div class="applications-section">
        <h2><i class="fas fa-file-alt"></i> @T.Get("Profile.MyApplications")</h2>

        @if (Model.Applications?.Any() == true)
        {
            foreach (var app in Model.Applications)
            {
                <div class="application-card">
                    <h3>@app.Job?.Title</h3>
                    <div class="application-meta">
                        <span class="status @app.Status.ToString().ToLower()">@T.Get($"Status.{app.Status}")</span>
                        <span class="date">@app.ApplyDate.ToString("dd.MM.yyyy")</span>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="no-applications">
                <p>@T.Get("Profile.NoApplications")</p>
                <a href="/Jobs" class="btn btn-primary">@T.Get("Profile.FindJobs")</a>
            </div>
        }
    </div>
</div>