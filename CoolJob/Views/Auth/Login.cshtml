@using CoolJob.Helpers
@model CoolJob.ViewModels.LoginViewModel

@{
    ViewData["Title"] = T.Get("Auth.Login.Title");
    ViewBag.Css = new[] { "css/style.css", "css/auth.css" };
}

<div class="auth-container">
    <div class="auth-card">
        <h2 class="auth-title">@T.Get("Auth.Login.Header")</h2>
        
        <form asp-action="Login" method="post" class="auth-form">
            <input type="hidden" asp-for="ReturnUrl" />
            
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>
            
            <div class="form-group">
                <label asp-for="Email" class="form-label">@T.Get("Auth.Login.Email")</label>
                <input asp-for="Email" class="form-control" placeholder="you@example.com" />
                <span asp-validation-for="Email" class="validation-message"></span>
            </div>
            
            <div class="form-group">
                <label asp-for="Password" class="form-label">@T.Get("Auth.Login.Password")</label>
                <input asp-for="Password" type="password" class="form-control" placeholder="••••••••" />
                <span asp-validation-for="Password" class="validation-message"></span>
            </div>

            <div class="form-group checkbox-group">
                <input asp-for="RememberMe" type="checkbox" class="form-check-input" id="RememberMe" />
                <label asp-for="RememberMe" class="form-label" for="RememberMe">@T.Get("Auth.Login.Remember")</label>
            </div>
            
            <button type="submit" class="auth-button">
                <i class="fas fa-sign-in-alt"></i> @T.Get("Auth.Login.Submit")
            </button>
            
            <div class="auth-links">
                <a asp-controller="Account" asp-action="Register">@T.Get("Auth.Login.ToRegister")</a>
                <span class="divider">|</span>
                <a href="#">@T.Get("Auth.Login.ForgotPassword")</a>
            </div>
        </form>
    </div>
</div>