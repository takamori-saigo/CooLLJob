@using CoolJob.Helpers
@using CoolJob.Models
@model IEnumerable<Job>

@{
    ViewData["Title"] = T.Get("Jobs.Title");
    ViewBag.Css = new[] { "css/style.css", "css/jobs.css"};
}

<div class="jobs-header">
    <h1>@T.Get("Jobs.Header")</h1>
    <form asp-action="Index" method="get" class="search-form">
        <input type="text" name="search" placeholder="@T.Get("Jobs.SearchPlaceholder")" value="@ViewBag.Search" />
        <select name="type" asp-items="@Html.GetEnumSelectList<JobType>()">
            <option value="">@T.Get("Jobs.AllTypes")</option>
        </select>
        <button type="submit">@T.Get("Jobs.SearchBtn")</button>
    </form>
</div>

<div class="jobs-container">
    @foreach (var item in Model)
    {
        <div class="job-card">
            <div class="job-header">
                <h3>@item.Title</h3>
                <!-- Динамический перевод типа занятости -->
                <span class="job-type @item.Type.ToString().ToLower()">@T.Get($"JobType.{item.Type}")</span>
            </div>
            
            <div class="job-body">
                <p class="employer">@item.Employer?.Name</p>
                <p class="salary">@(item.Salary != null ? $"{item.Salary:N0} ₽" : T.Get("Jobs.SalaryNotSpecified"))</p>
                <p class="description">@item.Description</p>
            </div>
            
            <div class="job-footer">
                <a asp-action="Details" asp-route-id="@item.Id" class="btn-details">@T.Get("Jobs.Details")</a>
                @if (User.Identity.IsAuthenticated)
                {
                    <form asp-action="Apply" method="post">
                        <input type="hidden" name="id" value="@item.Id" />
                        <button type="submit" class="btn-apply">@T.Get("Jobs.Apply")</button>
                    </form>
                }
            </div>
        </div>
    }
</div>