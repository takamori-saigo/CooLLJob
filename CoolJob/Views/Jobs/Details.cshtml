@using CoolJob.Helpers
@model Job

@{
    ViewData["Title"] = Model.Title;
    ViewBag.Css = new[] { "css/style.css", "css/jobs.css"};
}

<div class="job-details">
    <div class="job-header">
        <h1>@Model.Title</h1>
        <div class="job-meta">
            <span class="employer">@Model.Employer?.Name</span>
            <span class="type @Model.Type.ToString().ToLower()">@T.Get($"JobType.{Model.Type}")</span>
            <span class="salary">@(Model.Salary != null ? $"{Model.Salary:N0} ₽" : T.Get("Jobs.SalaryNotSpecified"))</span>
            <span class="date">@T.Get("Jobs.Details.Published"): @Model.PostDate.ToString("d")</span>
        </div>
    </div>

    <div class="job-description">
        <h3>@T.Get("Jobs.Details.Title")</h3>
        <p>@Model.Description</p>
    </div>

    <div class="job-actions">
        @if (User.Identity.IsAuthenticated)
        {
            <form asp-action="Apply" method="post">
                <input type="hidden" name="id" value="@Model.Id" />
                <button type="submit" class="btn-apply">
                    <i class="fas fa-paper-plane"></i> @T.Get("Jobs.Details.Apply")
                </button>
            </form>
        }
        else
        {
            <a asp-controller="Auth" asp-action="Login" asp-route-returnUrl="@Context.Request.Path" class="btn-apply">
                <i class="fas fa-sign-in-alt"></i> @T.Get("Jobs.Details.LoginToApply")
            </a>
        }
        <a asp-action="Index" class="btn-back">@T.Get("Jobs.Details.Back")</a>
    </div>
</div>